# Staging Supabase project — copy to .env.staging and fill in from
# supabase.com → your STAGING project → Settings → API.
# Used by `npm run dev:staging` (Vite --mode staging); `npm run dev`
# keeps using .env (production project).
VITE_SUPABASE_URL=https://YOUR-STAGING-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-STAGING-ANON-KEY
