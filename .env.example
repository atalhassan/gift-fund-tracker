# Copy this file to ".env" and fill in both values from your Supabase project.
# Supabase Dashboard → Project Settings → API
#
# These are exposed in the browser bundle — that is expected and safe.
# The anon key is public by design; Row-Level Security is what protects your data.
# NEVER put the service_role key here.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
